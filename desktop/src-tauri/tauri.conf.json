{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MiniChat",
  "version": "1.0.0",
  "identifier": "com.enterprise.minichat",
  "build": {
    "beforeDevCommand": "cd ../web && npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "cd ../web && npm run build",
    "frontendDist": "/Users/jithendranara/chatbot-enterprise/web/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MiniChat",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "notification": {
      "all": true
    }
  }
}
